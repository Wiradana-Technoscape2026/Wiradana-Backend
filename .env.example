APP_PORT=8080
APP_NAME=Wiradana Backend

DATABASE_DSN=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_MIGRATION_DSN=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require

JWT_SECRET=your-random-secret-minimum-32-characters
JWT_EXPIRATION_HOURS=24

OCR_API_KEY=YOUR_API_CO_ID_KEY
OCR_BASE_URL=https://use.api.co.id

# Notifikasi WhatsApp
# WA_MODE=mock      → log ke DB saja (default, aman untuk demo)
# WA_MODE=sandbox   → kirim ke WhatsApp Cloud API sandbox (butuh token & phone_id)
WA_MODE=mock
WA_TOKEN=
WA_PHONE_ID=
